{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schema/audit_record.schema.json",
  "title": "AuditRecord",
  "description": "One row of the compliance gate audit log.",
  "type": "object",
  "required": [
    "candidate_id",
    "decision",
    "reason",
    "rule_results",
    "timestamp",
    "input_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "candidate_id": {
      "type": "string",
      "description": "Stable identifier for the candidate record. May be empty for anonymous inputs."
    },
    "decision": {
      "type": "string",
      "enum": ["PASS", "REJECT", "ESCALATE"],
      "description": "Aggregate decision produced by the gate."
    },
    "reason": {
      "type": "string",
      "description": "Human-readable aggregate reason."
    },
    "rule_results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["rule_name", "decision", "reason"],
        "additionalProperties": false,
        "properties": {
          "rule_name": {"type": "string"},
          "decision": {
            "type": "string",
            "enum": ["PASS", "REJECT", "ESCALATE"]
          },
          "reason": {"type": "string"},
          "metadata": {
            "type": "object",
            "description": "Structured context for the decision (optional)."
          }
        }
      }
    },
    "timestamp": {
      "type": "number",
      "description": "Unix timestamp (seconds) when the gate evaluated this record."
    },
    "input_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$",
      "description": "SHA-256 hash of the canonical-JSON-serialized candidate input."
    }
  }
}
